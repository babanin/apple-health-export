  "panels": [
    {
      "id": 1,
      "title": "Readiness",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "clamp_max(clamp_min((40 + 20 * clamp_max((avg_over_time(apple_health_heart_rate_variability_ms{source=~\"$source\"}[7d])) / clamp_min((avg_over_time(apple_health_heart_rate_variability_ms{source=~\"$source\"}[30d])), 1), 1.5) + 20 * clamp_max(((sum(count_over_time(apple_health_sleep_stage{source=~\"$source\",stage=~\"Asleep|Core|Deep|REM\"}[1d])) * 60) / 3600 / 8), 1) + 20 * clamp_max((avg_over_time(apple_health_resting_heart_rate_bpm{source=~\"$source\"}[30d])) / clamp_min((avg_over_time(apple_health_resting_heart_rate_bpm{source=~\"$source\"}[7d])), 1), 1.2) - 10 * clamp_min(((sum(sum_over_time(apple_health_workout_energy_kcal{source=~\"$source\",type=~\"$workout_type\"}[7d]))) / clamp_min((sum(sum_over_time(apple_health_workout_energy_kcal{source=~\"$source\",type=~\"$workout_type\"}[28d])) / 4), 1)) - 1, 0)), 0), 100)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 45,
                "color": "orange"
              },
              {
                "value": 65,
                "color": "yellow"
              },
              {
                "value": 80,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
