{
  "uid": "apple-health-workouts",
  "title": "Apple Health - Workouts",
  "tags": [
    "apple-health",
    "health",
    "ios",
    "curated"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "source",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "definition": "label_values({__name__=~\"apple_health_.*\"}, source)",
        "query": "label_values({__name__=~\"apple_health_.*\"}, source)",
        "label": "Source",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "workout_type",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "definition": "label_values(apple_health_workout_duration_seconds{source=~\"$source\"}, type)",
        "query": "label_values(apple_health_workout_duration_seconds{source=~\"$source\"}, type)",
        "label": "Workout Type",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "workout_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "definition": "label_values(apple_health_workout_duration_seconds{source=~\"$source\",type=~\"$workout_type\"}, workout_id)",
        "query": "label_values(apple_health_workout_duration_seconds{source=~\"$source\",type=~\"$workout_type\"}, workout_id)",
        "label": "Workout",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Workout Duration",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "last_over_time(apple_health_workout_duration_seconds{source=~\"$source\",type=~\"$workout_type\",workout_id=~\"$workout_id\"}[$__range])",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
